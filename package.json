{
  "name": "treed-shell",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:mock": "vite --mode mock",
    "dev:live": "vite --mode live",
    "dev:mock:5in": "vite --mode mock --open /?view=physical-5",
    "dev:mock:6in": "vite --mode mock --open /?view=physical-6",
    "dev:live:5in": "vite --mode live --open /?view=physical-5",
    "dev:live:6in": "vite --mode live --open /?view=physical-6",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:visual": "playwright test",
    "test:visual:layout": "playwright test e2e/shell-layout.spec.ts",
    "verify:ui": "npm run lint && npm run typecheck && npm run test -- --run && npm run test:visual:layout",
    "preview": "vite preview",
    "preview:960": "vite preview --host 127.0.0.1 --port 4173",
    "preview:960:5in": "vite preview --host 127.0.0.1 --port 4173 --open /?view=physical-5",
    "preview:960:6in": "vite preview --host 127.0.0.1 --port 4173 --open /?view=physical-6",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^28.1.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
